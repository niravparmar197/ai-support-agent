generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  ADMIN
  MANAGER
  SUPPORT
  VIEWER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users   User[]
  tickets Ticket[]
}

model User {
  id             String @id @default(cuid())
  organizationId String

  name     String
  email    String @unique
  password String

  status UserStatus @default(ACTIVE)
  role   UserRole   @default(SUPPORT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  refreshToken String?

  organization Organization @relation(fields: [organizationId], references: [id])

  tickets Ticket[]
}

model Ticket {
  id String @id @default(cuid())

  organizationId String
  userId         String

  title       String
  description String

  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  user User @relation(fields: [userId], references: [id])
}
